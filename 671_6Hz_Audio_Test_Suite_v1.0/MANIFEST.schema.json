{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Audio Test Suite Manifest",
  "description": "Schema for validating the manifest of the 671.6 Hz Audio Test Suite",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^v\\d+\\.\\d+\\.\\d+$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "size": {
            "type": "integer",
            "minimum": 0
          }
        },
        "required": ["path", "sha256", "size"]
      }
    }
  },
  "required": ["version", "timestamp", "files"]
}