{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/tsx/dist/cli.mjs apps/server/server.ts",
    "build": "node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "clean": "node -e \"const fs=require('fs'); fs.rmSync('dist',{ recursive:true, force:true });\"",
    "lint": "node ./node_modules/typescript/bin/tsc --noEmit",
    "chorus-test": "node --import tsx --test src/lib/frequency-map.test.ts src/lib/chorus-stack/control-kernel.test.ts",
    "test:lattice": "node --import tsx --test src/lib/frequency-map.test.ts src/lib/chorus-stack/control-kernel.test.ts",
    "test:oracle": "node --import tsx --test oracle/__tests__/kernel.test.ts",
    "deploy": "chmod +x apps/server/deploy.sh && ./apps/server/deploy.sh"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@react-three/drei": "^9.88.16",
    "@react-three/fiber": "^8.15.11",
    "@tailwindcss/vite": "^4.1.14",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/three": "^0.160.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "recharts": "^2.15.0",
    "three": "^0.148.0",
    "vite": "^6.2.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
