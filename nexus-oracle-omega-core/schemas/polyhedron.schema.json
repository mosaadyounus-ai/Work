{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PolyhedronV3",
  "type": "object",
  "required": [
    "schema_version",
    "kind",
    "embedding",
    "vertices",
    "facets",
    "edges",
    "geometry"
  ],
  "properties": {
    "vertices": {
      "type": "array",
      "minItems": 3
    },
    "facets": {
      "type": "array",
      "minItems": 3
    },
    "edges": {
      "type": "array",
      "minItems": 3
    },
    "geometry": {
      "type": "object",
      "required": [
        "degenerate",
        "accepted",
        "affine_rank",
        "relation"
      ]
    }
  }
}
