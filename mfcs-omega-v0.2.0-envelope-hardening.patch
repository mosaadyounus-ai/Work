@@ -1,13 +1,48 @@
 ----------------------------- MODULE envelope-laws -----------------------------
-EXTENDS Naturals, Sequences
+EXTENDS Naturals, Sequences, FiniteSets
+
+(*************************************************************************** )
+(* Repository-local envelope laws module.                                  *)
+(*                                                                         *)
+(* This lower-case module is kept for compatibility with existing imports, *)
+(* patches, and notes. It defines the envelope as a set of constraints     *)
+(* over a finite state history rather than as system dynamics.             *)
+(*************************************************************************** )
+
+CONSTANTS
+    MaxDepth,
+    AllowedInputs,
+    MaxEnvelope
 
 VARIABLES state
 
-EnvelopeLaw1 ==
-    /\ Len(state) <= MaxDepth
+(* Each element of state is assumed to be an input symbol drawn from        *)
+(* AllowedInputs. The module constrains the history rather than evolving it. *)
 
-EnvelopeLaw2 ==
-    /\ \A i \in DOMAIN state:
+DepthBound ==
+    Len(state) <= MaxDepth
+
+InputBound ==
+    \A i \in DOMAIN state:
         state[i] \in AllowedInputs
 
+HistoryFinite ==
+    state \in Seq(AllowedInputs)
+
+(* A simple global budget for finite traces. When states are symbolic       *)
+(* atoms, cardinality is the only generic aggregate available.              *)
+EnvelopeBudget ==
+    Cardinality({ state[i] : i \in DOMAIN state }) <= MaxEnvelope
+
+InEnvelope ==
+    /\ HistoryFinite
+    /\ DepthBound
+    /\ InputBound
+    /\ EnvelopeBudget
+
+(* Backward-compatible aliases used by older notes and patches. *)
+EnvelopeLaw1 == DepthBound
+EnvelopeLaw2 == InputBound
+Envelope == InEnvelope
+
 =============================================================================
