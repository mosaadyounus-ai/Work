# GCP Configuration
PROJECT_ID=your-gcp-project-id
REGION=us-west1
SERVICE_NAME=omega-server

# Node Environment
NODE_ENV=production
PORT=8080

# API Keys
GEMINI_API_KEY=your-gemini-api-key-here

# WebSocket Configuration
WS_PATH=/
WS_HEARTBEAT_INTERVAL=618

# Deployment Options
DOCKER_IMAGE=gcr.io/${PROJECT_ID}/omega-server
CLOUD_RUN_PLATFORM=managed
